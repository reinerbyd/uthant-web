# --- Required in production ---
# Public site URL (drives canonical, OpenGraph, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Admin panel credentials (CHANGE THESE)
ADMIN_PASSWORD=change-me-to-a-strong-password
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

# Writable data directory — point this at a persistent disk in production
# (e.g. /data on Render/Railway). Holds content.json + uploads/.
DATA_DIR=/data

# --- Optional: contact-form email delivery (Resend) ---
# Without these, enquiries are just logged. With them, the form emails you.
# Get a key at resend.com. For a real sender, verify your domain and set
# CONTACT_FROM to an address on it (until then, onboarding@resend.dev works
# but only delivers to the Resend account owner's email).
RESEND_API_KEY=
CONTACT_TO=hello@uthant.com.my
CONTACT_FROM=U Thant <onboarding@resend.dev>

